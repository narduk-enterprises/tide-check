{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "tide-check",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "tide-check.nard.uk",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tide-check-db",
      "database_id": "2176c867-da11-4328-a79a-852fa713ca9e"
    }
  ]
}
